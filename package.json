{
  "name": "booking-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.6.2",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "turbo run dev --filter=web",
    "build": "turbo run build --filter=web",
    "start": "cd apps/web-public && npm run start",
    "hostinger:web-public:build": "npm run build --workspace=apps/web-public",
    "hostinger:web-public:start": "npm run start --workspace=apps/web-public",
    "hostinger:web-admin:build": "npm run build --workspace=apps/web-admin",
    "hostinger:web-admin:start": "npm run start --workspace=apps/web-admin",
    "hostinger:api:build": "npm run prisma:generate --workspace=apps/api && npm run prisma:migrate:deploy --workspace=apps/api && npm run build --workspace=apps/api",
    "hostinger:api:build:nomigrate": "npm run prisma:generate --workspace=apps/api && npm run build --workspace=apps/api",
    "hostinger:api:start": "npm run start --workspace=apps/api",
    "smoke:launch": "node scripts/smoke-launch.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
