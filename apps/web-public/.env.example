# Public app base URL
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Canonical API base used by public catalog, checkout, invoice, and buyer dashboard
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000/api

# Optional legacy alias. Keep empty when NEXT_PUBLIC_API_BASE_URL is set.
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:4000/api

# Force live API mode for staging/production.
NEXT_PUBLIC_API_MODE=live

# Dashboard/admin app base URL used by seller login bridge
NEXT_PUBLIC_ADMIN_APP_URL=http://127.0.0.1:3010

# Feature flags
NEXT_PUBLIC_SHOW_PROMOS=true
NEXT_PUBLIC_LEGACY_PARTNER_FORM=0
