# Server
PORT=4000
NODE_ENV=development

# CORS (comma-separated). Wajib pakai origin publik saat production.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3010,http://127.0.0.1:3010

# Public base URL backend
APP_BASE_URL=http://localhost:4000

# Public frontend base URL used for invoice redirects, affiliate links, and payment callbacks
PUBLIC_APP_URL=http://127.0.0.1:3000

# Database (Postgres, non-Docker default)
DATABASE_URL=mysql://root@127.0.0.1:3306/villa_db

# Midtrans (legacy / compat only)
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key

# Xendit (active)
XENDIT_SECRET_KEY=xnd_development_your_sandbox_secret_key
XENDIT_WEBHOOK_VERIFICATION_TOKEN=your_real_xendit_webhook_verification_token
# Legacy alias sementara bila deployment lama belum dipindah:
# XENDIT_CALLBACK_TOKEN=your_real_xendit_webhook_verification_token

# JWT
JWT_SECRET=please_change_me_super_secret
JWT_REFRESH_SECRET=please_change_me_super_secret_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Set true hanya jika API memang berjalan di Docker network dan host DB memang `db`
ALLOW_DOCKER_DB_HOST=false

# Dev/test toggles
ENABLE_ADMIN_MARKETPLACE_SEED=false

# Legacy compat fallback only. Keep empty in staging/production unless migration lama masih membutuhkannya.
# DEFAULT_PUBLIC_USER_ID=

# Observability (opsional)
SERVICE_NAME=booking-villa-api
